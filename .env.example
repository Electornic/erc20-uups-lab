# Copy to .env and fill in your values. NEVER commit .env.
# Get a free Sepolia RPC from Alchemy / Infura / drpc.org
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY

# Deployer private key (0x-prefixed). Use a TEST wallet only — never your main wallet.
PRIVATE_KEY=0xYOUR_TEST_WALLET_PRIVATE_KEY

# Etherscan v2 API key for contract verification
# https://etherscan.io/myapikey
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_API_KEY
